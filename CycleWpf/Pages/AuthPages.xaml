<Page x:Class="CycleWpf.Pages.AuthPages"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CycleWpf.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AuthPages">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <TextBlock Text="Авторизация"
            Grid.Column="1"
            Grid.ColumnSpan="2"
                   FontSize="30"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
            />
        <TextBlock Text="Логин:"
    Grid.Column="0"
                   Grid.Row="1"
    Grid.ColumnSpan="2"
           FontSize="30"
           HorizontalAlignment="Center"
           VerticalAlignment="Center"
    />
        <TextBlock Text="Пароль:"
    Grid.Column="0"
                   Grid.Row="2"
    Grid.ColumnSpan="2"
           FontSize="30"
           HorizontalAlignment="Center"
           VerticalAlignment="Center"
    />
        <TextBox x:Name="LoginTb"
                  Grid.Column="2"
                Grid.Row="1"
                 Width="150"
                 Height="40"
 
        FontSize="14"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
            
            />
        <PasswordBox x:Name="PasswordTb"
          Grid.Column="2"
        Grid.Row="2"
         Width="150"
         Height="40"
 
FontSize="14"
HorizontalAlignment="Center"
VerticalAlignment="Center"
    
    />
        <Button x:Name="AuthBtn"
                Click="AuthBtn_Click"
                Content="Войти"
                Grid.Row="3"
                Grid.ColumnSpan="2"
                 Width="250"
                    Height="50"
                FontSize="18"
                Foreground="White"
                Background="#4B0082"
                
            
            />
        <Button x:Name="GuestBtn"
        Click="GuestBtn_Click"
        Content="Роль гостя"
        Grid.Row="3"
                Grid.Column="2"
        Grid.ColumnSpan="2"
         Width="250"
            Height="50"
        FontSize="18"
                Foreground="White"
        Background="#4B0082"
        
    
    />
    </Grid>
    
</Page>
