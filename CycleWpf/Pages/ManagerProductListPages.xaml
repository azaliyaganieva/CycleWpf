<Page x:Class="CycleWpf.Pages.ManagerProductListPages"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CycleWpf.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ManagerProductListPages">

    <Grid Background="#6A5ACD">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Image Source="/Resources/icon.png" Width="80"/>
        <TextBlock Text="Список товаров "
                   FontSize="20"
                   Grid.Column="2"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap"
                   />
        <TextBlock x:Name="FIOTb" 
                   Grid.Column="4" 
                   FontSize="16"
                   TextWrapping="Wrap"/>
        <Button x:Name="BackBtn"
    Click="BackBtn_Click"
    Content="Выйти"
   
            Grid.Column="5"
    
     Width="120"
        Height="50"
    FontSize="18"
            Foreground="White"
    Background="#4B0082"
    

/>
        <ComboBox Grid.Row="1"
                  Width="120"
   Height="50"
                  Grid.ColumnSpan="2"
                 
                  Name="SortCmb"
                  SelectionChanged="SortCmb_SelectionChanged"
                  >
            <ComboBoxItem Content="По возрастанию" FontSize="16"/>
            <ComboBoxItem Content="По убыванию" FontSize="16"/>
            <ComboBoxItem Content="По умолчанию" FontSize="16"/>
        </ComboBox>
        <ComboBox Name="SupplierCmb"
                  ItemsSource="{Binding suppliers}"
                  SelectionChanged="SupplierCmb_SelectionChanged"
                                 Width="120"
Height="50"
               Grid.ColumnSpan="2"
               DisplayMemberPath="Name"
                  Grid.Row="1"
                  Grid.Column="2">

        </ComboBox>
        <TextBox Name="SearchTb"
             TextChanged="SearchTb_TextChanged"
       Width="120"
                        Height="50"
       Grid.ColumnSpan="2"
      
          Grid.Row="1"
          Grid.Column="4"/>
        <ListView ItemsSource="{Binding products}"
                  Grid.Row="2"
                  Grid.RowSpan="4"
                  Grid.ColumnSpan="6"
                 Name="productLv"
                  >
            <ListView.ItemTemplate >
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Image Height="150" Width="150">
                                <Image.Source>
                                    <Binding Path="Photo">
                                        <Binding.TargetNullValue>
                                            <Image Source="/Resources/picture.png"/>
                                        </Binding.TargetNullValue>
                                    </Binding>
                                </Image.Source>
                            </Image>
                            <StackPanel Grid.Column="1 " Width="700">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Text="{Binding ProductCategory.Name}" 
                                               FontSize="16"/>
                                    <TextBlock Text="{Binding Name,StringFormat={}|:{0}}" 
                                               TextWrapping="Wrap"
                                               FontSize="16"/>
                                    <TextBlock Text="{Binding Description,StringFormat={}Описание товара:{0}}" 
                                               TextWrapping="Wrap"
                                               FontSize="16"/>
                                    <TextBlock Text="{Binding Manufacturer.Name,StringFormat={}Производитель:{0}}" 
                                            FontSize="16"/>
                                    <TextBlock Text="{Binding Supplier.Name,StringFormat={}Поставщик:{0}}" 
                                        FontSize="16"/>
                                    <TextBlock Text="{Binding Price,StringFormat={}Цена:{0}}" 
           FontSize="16"/>
                                    <TextBlock Text="{Binding Unit.Name,StringFormat={}Ед.измерения:{0}}" 
           FontSize="16"/>
                                    <TextBlock Text="{Binding WorkShopCount,StringFormat={}Кол-во на складе:{0}}" 
           FontSize="16"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Text="{Binding ActiveDiscount}"
                                       Grid.Column="2"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="18"
                                       />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </Grid>
</Page>
